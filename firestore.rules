rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /memoryCards/{cardId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    match /loveNotes/{noteId} {
      allow read, create: if true;
      allow update, delete: if false;
    }
  }
}
